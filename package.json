{
  "name": "@woheedev/tms-app",
  "version": "0.1.0",
  "description": "Trip Weather App - Plan better trips around the weather",
  "author": "woheedev",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "deploy": "turbo run deploy",
    "dev": "turbo run dev",
    "cleanup": "bun ./scripts/cleanup.mjs",
    "format": "prettier --write . && turbo run format",
    "format:check": "prettier --check . && turbo run format:check",
    "lint": "turbo run lint",
    "upgrade": "ncu -w -u && bun install && turbo run upgrade"
  },
  "devDependencies": {
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.12"
  },
  "packageManager": "bun@1.3.10"
}
